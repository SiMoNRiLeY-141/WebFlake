{
  "name": "webflake",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "deploy": "gh-pages -d public",
    "test": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "projects": [
      {
        "displayName": "server",
        "testEnvironment": "node",
        "testMatch": [
          "**/tests/server.test.js"
        ]
      },
      {
        "displayName": "frontend",
        "testEnvironment": "jsdom",
        "testMatch": [
          "**/tests/script.test.js"
        ]
      }
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "server.js",
      "public/script.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
